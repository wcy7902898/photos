/*
  Cache-Control: public, max-age=0, must-revalidate

/api/img/thumbs/*
  Cache-Control: public, max-age=86400, immutable
  Cache-Tag: photos-thumb

/api/img/medium/*
  Cache-Control: public, max-age=86400, immutable

/api/img/imgs/*
  Cache-Control: public, max-age=86400, immutable

*.css
  Cache-Control: public, max-age=3600
*.js
  Cache-Control: public, max-age=60
